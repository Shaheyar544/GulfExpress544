
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write access to site_configs
    match /site_configs/{document=**} {
      allow read, write: if true;
    }
    
    // Allow public read/write access to other collections used by the app
    // In production, these should be locked down to authenticated users/admin
    match /shipments/{document=**} {
      allow read, write: if true;
    }
    match /quotations/{document=**} {
      allow read, write: if true;
    }
    match /contact_messages/{document=**} {
      allow read, write: if true;
    }
    match /inquiries/{document=**} {
      allow read, write: if true;
    }
    match /bookings/{document=**} {
      allow read, write: if true;
    }
    match /newsletter_subscriptions/{document=**} {
      allow read, write: if true;
    }
    match /users/{document=**} {
      allow read, write: if true;
    }
    match /admins/{document=**} {
      allow read, write: if true;
    }
    match /settings/{document=**} {
      allow read, write: if true;
    }
    match /pickups/{document=**} {
      allow read, write: if true;
    }
    match /quotes/{document=**} {
      allow read, write: if true;
    }
    match /content/{document=**} {
      allow read, write: if true;
    }
    match /publicTrackingData/{document=**} {
      allow read, write: if true;
    }
    match /locations/{document=**} {
      allow read, write: if true;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
